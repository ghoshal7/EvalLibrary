{
  "mas_patterns": [
    "mas_orchestrator_worker"
  ],
  "flow": [
    "orchestrator->researcher",
    "orchestrator->writer"
  ],
  "flow_mode": "strict",
  "max_redundant_tool_calls": 0,
  "agents": {
    "researcher": {
      "task_pattern": "agent_tool_use",
      "scorers": [
        {
          "name": "tool_correctness"
        }
      ],
      "expected": {
        "tools": [
          {
            "name": "kb.search"
          }
        ]
      }
    },
    "writer": {
      "task_pattern": "rag",
      "scorers": [
        {
          "name": "regex_rules",
          "params": {
            "forbidden": [
              "cheese"
            ]
          }
        }
      ]
    }
  },
  "outcome": [
    {
      "name": "scenario_assertions",
      "params": {}
    }
  ]
}